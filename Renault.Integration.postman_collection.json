		{
			"name": "Renault.API (Direct)",
			"item": [
				{
					"name": "Renault Auth (v1/auth/client)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"accessKey\": \"{{renaultAccessKey}}\",\n    \"password\": \"{{renaultPassword}}\",\n    \"scope\": \"Crm\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://crmi.renault.com.br/v1/auth/client",
							"protocol": "https",
							"host": [
								"crmi",
								"renault",
								"com",
								"br"
							],
							"path": [
								"v1",
								"auth",
								"client"
							]
						},
						"description": "Valida as credenciais diretamente no ambiente de produção/homologação da Renault."
					},
					"response": []
				},
				{
					"name": "Consume Leads (v1/leads/consume)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{renaultToken}}",
								"type": "text"
							},
							{
								"key": "SecretKey",
								"value": "{{renaultSecret}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"bir\": \"{{renaultBir}}\",\n    \"startDate\": \"2025-03-10T00:00:00Z\",\n    \"endDate\": \"2025-03-12T23:59:59Z\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://crmi.renault.com.br/v1/leads/consume",
							"protocol": "https",
							"host": [
								"crmi",
								"renault",
								"com",
								"br"
							],
							"path": [
								"v1",
								"leads",
								"consume"
							]
						},
						"description": "Interface direta para consumir leads da montadora Renault."
					},
					"response": []
				}
			],
			"description": "Integração direta com os endpoints oficiais da Renault para validação de acesso."
		}
