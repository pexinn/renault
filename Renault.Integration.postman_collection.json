						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"00Q0-SF-NEG-111\",\n    \"status\": \"NEGOTIATION\",\n    \"renaultLeadReferenceId\": \"REF-123456\",\n    \"firstName\": \"Ricardo\",\n    \"lastName\": \"Oliveira\",\n    \"email\": \"ricardo.oliveira@example.com\",\n    \"mobilePhone\": \"41988887777\",\n    \"modelOfInterest\": \"Duster 2024\",\n    \"interestType\": \"C\",\n    \"origin\": \"Showroom\",\n    \"leadSource\": \"Renault\"\n}",
