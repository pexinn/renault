{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MongoDB": "mongodb://localhost:27017"
  },
  "MongoDB": {
    "Database": "MsRenaultDB"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "UserName": "guest",
    "Password": "guest"
  },
  "Renault": {
    "BaseUrl": "https://crmi.renault.com.br",
    "AccessKey": "YOUR_ACCESS_KEY",
    "Password": "YOUR_PASSWORD",
    "Bir": "YOUR_BIR_CODE",
    "LojaCnpj": "YOUR_LOJA_CNPJ"
  },
  "Filas": {
    "Leads": "leads_prd",
    "RenaultAtualizarLeadEnvio": "renault_atualizar_lead_envio_prd",
    "RenaultAtualizarLeadRetorno": "renault_atualizar_lead_retorno_prd",
    "ProcessRenault": "process.msrenault.prd"
  },
  "Ingestion": {
    "IntervalMinutes": 15
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317",
    "ConsoleExporter": true
  }
}
